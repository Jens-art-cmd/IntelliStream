# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here  # NEVER expose to browser

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (Embeddings: text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Resend (Newsletter)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=newsletter@intellistream.de

# Redis / Upstash (Message Queue)
REDIS_URL=redis://...

# n8n
N8N_WEBHOOK_URL=https://your-n8n.hetzner.instance.com/webhook

# App
PORT=4000
NODE_ENV=development
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000,https://intellistream.de
