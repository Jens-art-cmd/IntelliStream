# Supabase (public — safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# API
NEXT_PUBLIC_API_URL=http://localhost:4000

# App-URL (für Stripe Redirect nach Checkout)
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Stripe (server-only — NIEMALS NEXT_PUBLIC_ prefix!)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

# Sentry — Error Monitoring (https://sentry.io)
# DSN: Settings → Projects → [Projekt] → Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# Org/Project: für Source-Map-Upload beim Build (nur Vercel Build-Env benötigt)
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=distillfeed-web
# Auth-Token: Settings → Auth Tokens → Token mit project:releases + org:read Scope
SENTRY_AUTH_TOKEN=sntrys_...
